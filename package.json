  "description": "OpenCode plugin that auto-sends continue on session errors",
  "main": "./dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "scripts": {
