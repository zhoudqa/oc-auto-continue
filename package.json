  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.4.0",
    "@opencode-ai/sdk": "^1.4.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.0",
    "@opencode-ai/sdk": "^1.4.0",
    "bun-types": "1.3.11",
    "typescript": "^5.7.3"
  }
